# Keep version stamping support
src/clientversion.cpp export-subst

# Normalize text to LF (prevents CRLF noise across platforms)
* text=auto eol=lf

# Explicitly enforce LF for common doc/script formats
*.md text eol=lf
*.txt text eol=lf
*.sh  text eol=lf
*.py  text eol=lf
src/test/data/*.inl text eol=lf
